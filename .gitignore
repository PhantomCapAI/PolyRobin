# PolyRobin local state — never commit runtime data, keys, or audit logs
.polyrobin/
*.audit
audit/
*.log

# Secrets & keys (PolyRobin never stores keys, but guard anyway)
.env
.env.*
*.key
*.pem
*.keystore
secrets.yaml
config.local.yaml

